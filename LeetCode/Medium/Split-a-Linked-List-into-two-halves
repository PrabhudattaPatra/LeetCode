class Solution:
    def splitList(self, head):
        #code here
        slow = head
        fast = head.next
        
        while fast.next != head:
            slow = slow.next
            fast = fast.next
            
            if fast.next != head:
                fast = fast.next
        
        second_head = slow.next
        fast.next = second_head
        slow.next = head
        
        return head,second_head
